<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.xthan.xquicksettings">

    <uses-permission android:name="android.permission.WRITE_SETTINGS" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.xQuickSettings">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Invisible Volume Helper Activity -->
        <activity
            android:name=".VolumeHelperActivity"
            android:theme="@style/Theme.VolumeHelper"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:taskAffinity=""
            android:exported="false" />

        <!-- Volume Tile Service -->
        <service
            android:name=".VolumeTileService"
            android:icon="@drawable/ic_volume_up"
            android:label="@string/tile_volume_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- Navigation Mode Tile Service -->
        <service
            android:name=".NavigationTileService"
            android:icon="@drawable/ic_settings_nav"
            android:label="@string/tile_nav_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- Rotation Tile Service -->
        <service
            android:name=".RotationTileService"
            android:icon="@drawable/ic_rotation_locked"
            android:label="@string/tile_rotation_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

    </application>
</manifest>